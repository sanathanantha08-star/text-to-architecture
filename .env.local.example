# Cohere API — get a key at https://dashboard.cohere.com/api-keys
# If COHERE_API_KEY is left blank, the app runs in MOCK mode and returns a
# deterministic sample diagram so you can develop the UI without a key.
COHERE_API_KEY=

# Model name (swap freely as Cohere ships newer models)
COHERE_MODEL=command-r-plus-08-2024
